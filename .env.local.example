# 复制本文件为 .env.local 并填写你的 Supabase 项目信息
# Supabase 控制台 -> Project Settings -> API 中可以找到

# 公开可用（会打包进前端），使用 anon / public 公钥
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# 仅服务端使用（切勿加 NEXT_PUBLIC_ 前缀，切勿泄露到浏览器）
# 用于在后台「登录账号」页面直接创建/删除 Supabase Auth 用户
# 使用 service_role / secret 私钥
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-SECRET-KEY
